/* Reset */
body {
    margin: 0;
    padding: 0;
    background: black;

    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
}

/* Canvas utama */
.container {
    position: relative;
    width: 90vw;   /* 90% dari screen width */
    max-width: 1080px; /* jangan lebih dari design desktop */
    height: auto; /* ikut aspect ratio */
    aspect-ratio: 1080 / 1400; /* pastikan maintain proportion */
    overflow: hidden;
}

.container img {
    max-width: 100%;  /* ikut container width */
    height: auto;
}

/* 🌌 Galaxy (kanan → kiri) */
.galaxy {
    position: absolute;
    top: 0;
    right: -100%;
    height: 100%;

    opacity: 0;
    animation: galaxyMasuk 3s ease forwards;
}

/* 🔵 Border PNG (kiri → kanan) */
.border-biru {
    position: absolute;
    top: 0;
    left: 0;

    width: auto;
    height: auto;
    max-width: 100%;

    opacity: 0;
    transform: translateX(-100%);

    animation: borderSlide 1.5s ease forwards;
    animation-delay: 0.5s;

    z-index: 2;
}

/* 🎴 Kad Raya */
.card {
    position: absolute;
    top: 50%;
    left: 50%;

    width: 600px;

    opacity: 0;
    transform: translate(-50%, 150px) scale(0.8);

    animation: kadMasuk 2s ease forwards;
    animation-delay: 1.5s;

    z-index: 3;
}

/* ================= ANIMATIONS ================= */

/* Galaxy masuk */
@keyframes galaxyMasuk {
    0% {
        right: -100%;
        opacity: 0;
    }
    100% {
        right: 0;
        opacity: 1;
    }
}

/* Border slide kiri → kanan */
@keyframes borderSlide {
    0% {
        opacity: 0;
        transform: translateX(-100%);
    }
    100% {
        opacity: 1;
        transform: translateX(0);
    }
}

/* Kad naik dari bawah */
@keyframes kadMasuk {
    0% {
        opacity: 0;
        transform: translate(-50%, 200px) scale(0.6);
    }
    60% {
        opacity: 1;
        transform: translate(-50%, -20px) scale(1.05);
    }
    100% {
        transform: translate(-50%, 0) scale(1);
    }
}

.masjid {
    position: absolute;
    bottom: 0;
    right: 0;

    width: auto; /*ust ikut design */
    height: auto;

    opacity: 0; /* mula dari invisible */
    transform: translateY(200px) scale(0.5) rotate(20deg);

    animation: masjidMasuk 2.2s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    animation-delay: 2s;

    z-index: 1;

    filter: drop-shadow(0 0 15px rgba(0, 255, 200, 0.6));
}

@keyframes masjidMasuk {
    0% {
        opacity: 0;
        transform: translateY(200px) scale(0.4) rotate(25deg);
    }

    50% {
        opacity: 1; /* fade in complete */
        transform: translateY(-25px) scale(1.08) rotate(-5deg);
    }

    70% {
        transform: translateY(10px) scale(0.98) rotate(2deg);
    }

    100% {
        transform: translateY(0) scale(1) rotate(0deg);
        opacity: 1; /* tetap visible, no fade out */
    }
}

.pattern {
    position: absolute;
    top: 0;
    left: -100%; /* mula di luar kiri */
    width: 1080px;
    height: 1400px;

    opacity: 0.8; /* agak subtle */
    animation: patternMasuk 1.8s ease forwards;
    animation-delay: 0.2s;

    z-index: 0; /* PASTI di belakang semua */
}

@keyframes patternMasuk {
    0% {
        left: -100%;
    }
    100% {
        left: 0;
    }
}

.awan {
    position: absolute;
    top: 9%;
    left: 20%; /* mula dari kiri luar */
    transform: translate(-130%, -50%); /* start luar kiri + center vertikal */
    
    width: auto;
    height: auto;
    opacity: 1;

    /* main slide animation masuk */
    animation: awanMasuk 3s ease forwards, awanJiggling 6s ease-in-out infinite;
    animation-delay: 0.5s, 3s; /* slide dulu 3s, jiggling start selepas tu */
    
    z-index: 1;
}

@keyframes awanMasuk {
    0% {
        transform: translate(-100%, -50%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

@keyframes awanJiggling {
    0% {
        transform: translate(0, -50%);
    }
    25% {
        transform: translate(10px, -45%);
    }
    50% {
        transform: translate(-10px, -55%);
    }
    75% {
        transform: translate(5px, -52%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

.awan1 {
    position: absolute;
    top: 55%; 
    left: 15%; /* mula dari kiri luar */
    transform: translate(-1%, -10%); /* start di luar kiri + center vertikal */
    
    width: auto; 
    height: auto; 
    opacity: 1;

    animation: awanMasuk 3.4s ease forwards, jigglingawan1 5s ease-in-out infinite;
    animation-delay: 2.3s, 5s;

    z-index: 1; /* atas pattern tapi bawah border & kad */
}


@keyframes awanMasuk {
    0% {
        transform: translate(-100%, -50%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

@keyframes jigglingawan1 {
    0% {
        transform: translate(0, -50%);
    }
    25% {
        transform: translate(7px, -47%);
    }
    50% {
        transform: translate(-13px, -50%);
    }
    75% {
        transform: translate(9px, -48%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

.awan2 {
    position: absolute;
    top: 55%; 
    left: -30%; /* mula dari kiri luar */
    transform: translate(-1%, -5%); /* start di luar kiri + center vertikal */
    
    width: auto; 
    height: auto; 
    opacity: 1;

    animation: awanMasuk1 3.4s ease forwards, jigglingawan2 5s ease-in-out infinite;
    animation-delay: 3s, 6s;

    z-index: 1; /* atas pattern tapi bawah border & kad */
}


@keyframes awanMasuk1 {
    0% {
        transform: translate(-100%, -50%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

@keyframes jigglingawan2 {
    0% {
        transform: translate(0px, -50%);
    }
    25% {
        transform: translate(12px, -45%);
    }
    50% {
        transform: translate(-7px, -47%);
    }
    75% {
        transform: translate(15px, -53%);
    }
    100% {
        transform: translate(0, -50%);
    }
}

.logo {
    position: absolute; /* adjust ikut location, contohnya atas tengah */
    top: 20px;
    left: 50%;
    transform: translateX(-50%); /* center horizontal */

    width: auto ;  /* adjust ikut design */
    height: auto;

    opacity: 0; /* mula invisible */

    animation: logoFadeIn 3s ease forwards; /* fade in selama 2s */
    animation-delay: 2s; /* delay sebelum fade in (optional) */

    z-index: 10; /* pastikan di atas layer lain */
}

@keyframes logoFadeIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
}

.smoke {
    position: absolute; /* adjust ikut location, contohnya atas tengah */
    top: 20px;
    left: 50%;
    transform: translateX(-50%); /* center horizontal */

    width: auto ;  /* adjust ikut design */
    height: auto;

    opacity: 0; /* mula invisible */

    animation: logoFadeIn 3s ease forwards; /* fade in selama 2s */
    animation-delay: 2s; /* delay sebelum fade in (optional) */

    z-index: 10; /* pastikan di atas layer lain */
}
